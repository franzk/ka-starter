# ===================================
# MODE: SSH (Build local sur VPS)
# ===================================
# Ce fichier configure le déploiement en mode SSH classique.
# Les images sont buildées localement sur le VPS à partir du code Git.

# Les variables *_IMAGE ne sont pas définies, donc Docker utilisera
# les valeurs par défaut du docker-compose.yml (ex: ka-front, ka-gateway, etc.)
# et construira les images localement grâce aux sections "build:".

# ===================================
# VARIABLES D'ENVIRONNEMENT APPLICATIVES
# ===================================

# Keycloak
KEYCLOAK_URL=https://auth.example.com
KEYCLOAK_ISSUER=https://auth.example.com/realms/ka-starter
KEYCLOAK_HOST=ka-keycloak:8080

# Frontend
VITE_KEYCLOAK_REALM=ka-starter
VITE_KEYCLOAK_CLIENT_ID=ka-front
VITE_API_URL=https://api.example.com

# Gateway
BACK_URL=http://service-example:8080
APP_URL=https://app.example.com

# Database
KC_DB_PASSWORD=change-me

# Admin
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=change-me

# SMTP
MAILER_URL=http://ka-mailer:8080
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=change-me
SMTP_AUTH=true
SMTP_SSL=true

# Proxy (optionnel)
# PROXY_NETWORK_NAME=traefik-public

# Projet
PROJECT=ka-starter
